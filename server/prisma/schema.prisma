generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String? // optional for future OAuth
  name     String?
  verified Boolean @default(false)

  // keep existing storage logic (no breaking changes)
  storageUsed  BigInt @default(0)
  storageLimit BigInt @default(104857600)

  // new fields
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // existing relations
  notifications Notification[]
  files         File[]
  tokens        Token[]

  // future-ready relations (optional, won’t break anything)
  profile  UserProfile?
  settings UserSettings?
  accounts Account[]
  sessions Session[]
}


model UserProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio      String?
  location String?
  website  String?

  createdAt DateTime @default(now())
}


model UserSettings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme                String  @default("light")
  language             String  @default("en")
  emailNotifications   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Account {
  id                String @id @default(uuid())
  userId            String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          String
  providerAccountId String

  accessToken  String?
  refreshToken String?

  createdAt DateTime @default(now())

  @@unique([provider, providerAccountId])
}


model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())
}

model File {
  id      String @id @default(uuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  versions FileVersion[]

  @@index([ownerId])
}

model FileVersion {
  id     String @id @default(uuid())
  fileId String
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  versionNumber Int
  storageKey    String
  size          Int
  mimeType      String
  checksum      String?

  originalName String
  displayName  String

  createdAt DateTime @default(now())
  isCurrent Boolean  @default(true)

  @@unique([fileId, versionNumber])
  @@index([fileId])
}

model Token {
  id        String       @id @default(uuid())
  token     String       @unique
  purpose   TokenPurpose
  expiresAt DateTime
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token, purpose])
}

enum TokenPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  title   String
  message String
  meta    Json?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
}
